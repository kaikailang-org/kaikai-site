---
import { t, pathInLang, type Lang } from '../i18n/ui';
import { links } from '../lib/links';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tt = t(lang);

const navItems = [
  { href: pathInLang('/get-started', lang), key: 'nav.start' as const },
  { href: pathInLang('/examples', lang), key: 'nav.examples' as const },
  { href: pathInLang('/about', lang), key: 'nav.name' as const },
  { href: pathInLang('/book', lang), key: 'nav.book' as const },
  { href: pathInLang('/ecosystem', lang), key: 'nav.ecosystem' as const },
  { href: pathInLang('/community', lang), key: 'nav.community' as const },
];

const otherLang: Lang = lang === 'es' ? 'en' : 'es';
const otherPath = pathInLang(
  Astro.url.pathname.replace(/^\/en/, '') || '/',
  otherLang,
);
---

<header class="site-header">
  <div class="container header-inner">
    <a href={pathInLang('/', lang)} class="brand" aria-label="kaikai home">
      <img
        src="/kaikai-mark.svg"
        alt=""
        width="32"
        height="32"
        class="mark mark-light"
      />
      <img
        src="/kaikai-mark-dark.svg"
        alt=""
        width="32"
        height="32"
        class="mark mark-dark"
      />
      <span class="brand-name">kaikai</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        {navItems.map(({ href, key }) => (
          <li><a href={href}>{tt(key)}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a
        href={links.github.kaikai}
        class="icon-link"
        aria-label="GitHub"
        rel="noopener"
      >
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.27-5.24-5.67 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.07 11.07 0 0 1 5.8 0c2.21-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.8 1.18 1.83 1.18 3.08 0 4.42-2.7 5.38-5.27 5.66.42.36.79 1.07.79 2.16v3.2c0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
          />
        </svg>
      </a>
      <a href={otherPath} class="lang-switch" aria-label={`Switch to ${otherLang}`}>
        {otherLang === 'en' ? 'EN' : 'ES'}
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(8px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding-block: var(--space-3);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--fg);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }
  .brand:hover { text-decoration: none; }
  .mark { display: block; }
  .mark-light { display: block; }
  .mark-dark { display: none; }
  @media (prefers-color-scheme: dark) {
    .mark-light { display: none; }
    .mark-dark { display: block; }
  }
  .primary-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .primary-nav ul {
    display: flex;
    gap: var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }
  .primary-nav a {
    color: var(--fg-muted);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .primary-nav a:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .header-actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--fg-muted);
    width: 32px;
    height: 32px;
    border-radius: var(--radius);
  }
  .icon-link:hover {
    color: var(--fg);
    background: var(--bg-subtle);
    text-decoration: none;
  }
  .lang-switch {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
  }
  .lang-switch:hover {
    color: var(--fg);
    background: var(--bg-subtle);
    text-decoration: none;
  }
  @media (max-width: 720px) {
    .header-inner {
      flex-wrap: wrap;
    }
    .primary-nav {
      order: 3;
      width: 100%;
      justify-content: flex-start;
    }
    .primary-nav ul { gap: var(--space-4); }
  }
</style>
