---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, t, type Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description, lang: explicitLang } = Astro.props;
const lang: Lang = explicitLang ?? getLangFromUrl(Astro.url);
const desc =
  description ??
  (lang === 'es'
    ? 'Lenguaje funcional con efectos algebraicos. Diseñado para programar con y por agentes.'
    : 'A functional language with algebraic effects. Designed to be written with and by agents.');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={desc} />

    <link rel="icon" type="image/svg+xml" href="/kaikai-mark.svg" />
    <link rel="icon" type="image/x-icon" href="/kaikai-favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/kaikai-mark-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/kaikai-mark-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/kaikai-apple-touch-icon.png" />

    <meta name="theme-color" content="#0d3b66" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f1419" media="(prefers-color-scheme: dark)" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content="https://kaikai-lang.org/kaikai-og-1200x630.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://kaikai-lang.org${Astro.url.pathname}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content="https://kaikai-lang.org/kaikai-og-1200x630.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
