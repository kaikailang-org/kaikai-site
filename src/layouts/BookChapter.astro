---
import Base from './Base.astro';
import { t, type Lang } from '../i18n/ui';
import { getBookChapters, bookChapterPath, type BookEntry } from '../lib/book';

interface Props {
  entry: BookEntry;
  prev?: BookEntry;
  next?: BookEntry;
}

const { entry, prev, next } = Astro.props;
const lang: Lang = entry.data.lang;
const tt = t(lang);

const chapters = await getBookChapters(lang);
const mainChapters = chapters.filter((c) => c.data.part === 'chapter');
const appendices = chapters.filter((c) => c.data.part === 'appendix');
const indexPath = bookChapterPath(lang, '').replace(/\/$/, '');

function tocLink(c: BookEntry) {
  return {
    href: bookChapterPath(lang, c.data.slug),
    title: c.data.title,
    current: c.data.slug === entry.data.slug,
  };
}
---

<Base title={`${entry.data.title} · kaikai`} lang={lang}>
  <div class="book-reader container">
    <aside class="book-toc" aria-label={tt('book.contents')}>
      <a class="toc-home" href={indexPath}>{tt('nav.book')}</a>
      <nav>
        <p class="toc-heading">{tt('book.chapters')}</p>
        <ol class="toc-list">
          {mainChapters.map((c) => {
            const l = tocLink(c);
            return (
              <li>
                <a href={l.href} aria-current={l.current ? 'page' : undefined}>
                  {l.title}
                </a>
              </li>
            );
          })}
        </ol>
        {appendices.length > 0 && (
          <>
            <p class="toc-heading">{tt('book.appendices')}</p>
            <ol class="toc-list">
              {appendices.map((c) => {
                const l = tocLink(c);
                return (
                  <li>
                    <a href={l.href} aria-current={l.current ? 'page' : undefined}>
                      {l.title}
                    </a>
                  </li>
                );
              })}
            </ol>
          </>
        )}
      </nav>
    </aside>

    <article class="book-content">
      <header class="chapter-head">
        <a class="eyebrow" href={indexPath}>{tt('nav.book')}</a>
        <h1>{entry.data.title}</h1>
      </header>

      <div class="prose book-prose">
        <slot />
      </div>

      <nav class="chapter-nav" aria-label={tt('book.contents')}>
        {prev ? (
          <a class="nav-prev" href={bookChapterPath(lang, prev.data.slug)}>
            <span class="nav-dir">‹ {tt('book.prev')}</span>
            <span class="nav-title">{prev.data.title}</span>
          </a>
        ) : (
          <span></span>
        )}
        {next ? (
          <a class="nav-next" href={bookChapterPath(lang, next.data.slug)}>
            <span class="nav-dir">{tt('book.next')} ›</span>
            <span class="nav-title">{next.data.title}</span>
          </a>
        ) : (
          <span></span>
        )}
      </nav>

      <p class="back-to-index">
        <a href={indexPath}>← {tt('book.backToIndex')}</a>
      </p>
    </article>
  </div>
</Base>

<style>
  .book-reader {
    display: grid;
    grid-template-columns: minmax(0, 16rem) minmax(0, 1fr);
    gap: var(--space-12);
    align-items: start;
    padding-block: var(--space-12);
  }

  /* --- Table of contents ------------------------------------------------ */
  .book-toc {
    position: sticky;
    top: calc(var(--space-16) + var(--space-2));
    max-height: calc(100vh - var(--space-24));
    overflow-y: auto;
    font-size: 0.9rem;
    border-right: 1px solid var(--border);
    padding-right: var(--space-6);
  }
  .toc-home {
    display: block;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-4);
  }
  .toc-home:hover { text-decoration: none; color: var(--accent); }
  .toc-heading {
    color: var(--fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 600;
    margin: var(--space-6) 0 var(--space-2);
  }
  .toc-list {
    list-style: none;
    margin: 0 0 var(--space-2);
    padding: 0;
    counter-reset: none;
  }
  .toc-list li { margin: 0; }
  .toc-list a {
    display: block;
    color: var(--fg-muted);
    padding: 0.28rem 0.5rem;
    border-radius: var(--radius);
    line-height: 1.35;
    border-left: 2px solid transparent;
  }
  .toc-list a:hover {
    color: var(--fg);
    background: var(--bg-subtle);
    text-decoration: none;
  }
  .toc-list a[aria-current='page'] {
    color: var(--accent);
    font-weight: 600;
    border-left-color: var(--accent);
    background: var(--bg-subtle);
  }

  /* --- Chapter content -------------------------------------------------- */
  .book-content { min-width: 0; }
  .chapter-head {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border);
  }
  .eyebrow {
    display: inline-block;
    color: var(--accent);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
    font-weight: 600;
  }
  .chapter-head h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
  }
  .book-prose { max-width: 68ch; }

  /* --- Prev / next ------------------------------------------------------ */
  .chapter-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-16);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border);
  }
  .chapter-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    max-width: 48%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--fg-muted);
  }
  .chapter-nav a:hover {
    border-color: var(--border-strong);
    background: var(--bg-subtle);
    text-decoration: none;
  }
  .nav-next { text-align: right; align-items: flex-end; }
  .nav-dir { font-size: 0.8rem; color: var(--accent); font-weight: 600; }
  .nav-title {
    font-family: var(--font-serif);
    color: var(--fg);
    font-size: 0.95rem;
    line-height: 1.3;
  }
  .back-to-index {
    margin-top: var(--space-6);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .book-reader {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .book-toc {
      position: static;
      max-height: none;
      border-right: 0;
      border-bottom: 1px solid var(--border);
      padding-right: 0;
      padding-bottom: var(--space-6);
    }
  }
</style>

<style is:global>
  /* Book prose: figures, tables, blockquotes, footnotes, code blocks. */
  .book-prose img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: var(--space-6) auto;
    border-radius: var(--radius);
  }
  .book-prose pre.astro-code {
    background: var(--code-bg) !important;
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius);
    overflow-x: auto;
    font-size: 0.86rem;
    line-height: 1.55;
    margin-block: var(--space-4) var(--space-6);
  }
  .book-prose :not(pre) > code {
    font-family: var(--font-mono);
  }
  .book-prose blockquote {
    margin: var(--space-6) 0;
    padding: var(--space-2) var(--space-6);
    border-left: 3px solid var(--accent-soft);
    color: var(--fg-muted);
    font-style: italic;
  }
  .book-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
    font-family: var(--font-sans);
    font-size: 0.92rem;
  }
  .book-prose th,
  .book-prose td {
    border: 1px solid var(--border);
    padding: 0.5rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  .book-prose th { background: var(--bg-subtle); font-weight: 600; }
  .book-prose h2,
  .book-prose h3 {
    scroll-margin-top: var(--space-16);
  }
  .book-prose .footnotes {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--fg-muted);
  }
</style>
